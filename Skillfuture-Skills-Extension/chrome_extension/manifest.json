{
  "manifest_version": 3,
  "name": "SkillsFuture Analyzer Hook",
  "version": "0.5.0",
  "description": "Analyzes job skills and provides semantic SkillsFuture course recommendations and credit planning.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html",
        "dashboard.js"
      ],
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://www.mycareersfuture.gov.sg/*",
        "https://mycareersfuture.gov.sg/*",
        "https://*.mycareersfuture.gov.sg/*",
        "https://www.jobstreet.com.sg/*",
        "https://sg.jobstreet.com/*",
        "https://*.jobstreet.com.sg/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "file:///*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*",
        "https://www.mycareersfuture.gov.sg/*",
        "https://mycareersfuture.gov.sg/*",
        "https://*.mycareersfuture.gov.sg/*",
        "https://www.jobstreet.com.sg/*",
        "https://sg.jobstreet.com/*",
        "https://*.jobstreet.com.sg/*",
        "http://localhost/*",
        "http://127.0.0.1/*",
        "file:///*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
